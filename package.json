{
  "name": "@binary-signal/vite-plugin-autocaddy",
  "type": "module",
  "version": "0.1.4",
  "description": "Vite plugin that automatically registers local dev servers with Caddy reverse proxy",
  "packageManager": "pnpm@10.33.0",
  "license": "MIT",
  "homepage": "https://github.com/binary-signal/vite-plugin-autocaddy#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/binary-signal/vite-plugin-autocaddy.git"
  },
  "bugs": {
    "url": "https://github.com/binary-signal/vite-plugin-autocaddy/issue"
  },
  "keywords": [
    "vite",
    "plugin",
    "vite-plugin",
    "caddy",
    "autocaddy",
    "reverse",
    "proxy",
    "reverse-proxy",
    "dev"
  ],
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "oxlint",
    "prepublishOnly": "pnpm build"
  },
  "peerDependencies": {
    "vite": ">=5.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "oxlint": "^1.60.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3",
    "vite": "^8.0.8"
  }
}

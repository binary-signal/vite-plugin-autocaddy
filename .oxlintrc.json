{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": [
    "typescript",
    "unicorn",
    "oxc"
  ],
  "categories": {
    "correctness": "error",
    "suspicious": "error",
    "pedantic": "warn",
    "perf": "warn"
  },
  "rules": {},
  "env": {
    "builtin": true
  },
  "options": {
    "typeAware": false,
    "typeCheck": false,
    "maxWarnings": 10
  }
}
